# Cole esses valores nas variáveis de ambiente do Railway
# (não suba este arquivo com os valores reais para o GitHub)

# 1. Chave da API da Anthropic
# Onde pegar: https://console.anthropic.com → API Keys → Create Key
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# 2. Credenciais da Z-API
# Onde pegar: app.z-api.io → sua instância → Credenciais
ZAPI_INSTANCE_ID=SEU_INSTANCE_ID
ZAPI_TOKEN=SEU_TOKEN
ZAPI_CLIENT_TOKEN=SEU_CLIENT_TOKEN

# 3. Número do manager para receber alertas de lead qualificado
# Formato: 5531999998888 (DDI + DDD + número, sem + ou espaço)
MANAGER_PHONE=5531999998888

# ⚠️ NÃO adicione PORT aqui — o Railway injeta automaticamente
